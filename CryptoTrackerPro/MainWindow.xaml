<Window x:Class="CryptoTrackerPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:lvcCore="clr-namespace:LiveChartsCore.SkiaSharpView;assembly=LiveChartsCore.SkiaSharpView"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:converters="clr-namespace:CryptoTrackerPro.Converters"
        Title="Crypto AI Tracker Pro" Height="800" Width="1150"
        Icon="/bitcoin.ico"
        Background="#121212" Foreground="White"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <converters:PauseTextConverter x:Key="PauseTextConverter"/>
        <converters:PauseColorConverter x:Key="PauseColorConverter"/>
        <Style x:Key="ModernContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="#1e1e1e"/>
            <Setter Property="BorderBrush" Value="#3d3d3d"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="0,5">
                            <StackPanel IsItemsHost="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ComboBox ItemsSource="{Binding Symbols}" 
                  SelectedItem="{Binding SelectedSymbol}" 
                  Width="120" Height="35" FontSize="14" FontWeight="Bold"
                  Background="#2d2d2d" Foreground="#F7931A"/>

                <TextBlock Text="{Binding SelectedSymbol}" FontSize="28" FontWeight="Bold" VerticalAlignment="Center" Foreground="#F7931A" Margin="15,0"/>
                <TextBlock Text="{Binding CurrentPrice, StringFormat='{}{0:N2} USD'}" 
                   FontSize="32" Foreground="SpringGreen" VerticalAlignment="Center" FontWeight="SemiBold"/>
            </StackPanel>

            <Border HorizontalAlignment="Right" VerticalAlignment="Center" 
            Background="#1e1e1e" CornerRadius="8" BorderBrush="#333" BorderThickness="1" 
            Padding="15,5" Margin="10,0,10,0">
                <StackPanel Orientation="Horizontal">
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="PORTFÓLIÓ ÉRTÉK" Foreground="Gray" FontSize="9" FontWeight="Bold"/>
                        <TextBlock Text="{Binding PortfolioValue}" Foreground="White" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>

                    <Separator Width="1" Height="25" Background="#444" Margin="5,0"/>

                    <StackPanel Margin="15,0,0,0">
                        <TextBlock Text="EGYENLEG" Foreground="Gray" FontSize="9" FontWeight="Bold"/>
                        <TextBlock Text="{Binding VirtualBalance, StringFormat='{}{0:N2} USDT'}" Foreground="LightGray" FontSize="14" VerticalAlignment="Bottom"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DockPanel>

        <lvc:CartesianChart Grid.Row="1" Grid.Column="0"
                    Series="{Binding Series}"
                    XAxes="{Binding XAxes}"
                    YAxes="{Binding YAxes}"
                    Sections="{Binding Sections}"
                    AnimationsSpeed="00:00:00.000"
                    Margin="0,0,10,0">
        </lvc:CartesianChart>

        <Grid Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Margin="10,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1e1e1e" BorderBrush="#F7931A" BorderThickness="1" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="AI TREND JÓSLAT" Foreground="#F7931A" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding TrendDirection}" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding PredictedPrice, StringFormat='Célár: {0:N2} USD'}" Foreground="Gray" FontSize="12" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="#1e1e1e" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="PIACI MUTATÓK" Foreground="Gray" FontSize="10" FontWeight="Bold" Margin="0,0,0,15"/>
                    <DockPanel Margin="0,5">
                        <TextBlock Text="Piac állapota:" Foreground="LightGray"/>
                        <TextBlock Text="{Binding MarketSentiment}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </DockPanel>
                    <DockPanel Margin="0,5">
                        <TextBlock Text="RSI (14):" Foreground="LightGray"/>
                        <TextBlock Text="{Binding RsiValue}" Foreground="SpringGreen" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </DockPanel>
                    <Separator Background="#333" Margin="0,10"/>
                    <DockPanel Margin="0,5">
                        <TextBlock Text="Volatilitás:" Foreground="LightGray"/>
                        <TextBlock Text="{Binding Volatility, StringFormat='{}{0:N2}'}" Foreground="White" HorizontalAlignment="Right"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Background="#1e1e1e" CornerRadius="10" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="ESEMÉNYNAPLÓ" Foreground="Gray" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding EventLog}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Time}" Foreground="Gray" FontSize="11" VerticalAlignment="Top"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Message}" Foreground="{Binding Color}" FontSize="11" TextWrapping="Wrap" Margin="5,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Button Grid.Row="2" Command="{Binding ExportLogCommand}" Content="NAPLÓ MENTÉSE (.TXT)" 
                            Background="#333" Foreground="Gray" FontSize="10" Margin="0,10,0,0" Height="25" BorderThickness="0"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#1e1e1e" CornerRadius="10" Padding="12" Margin="0,20,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="🔔 Riasztás:" VerticalAlignment="Center" Foreground="Gray" Margin="0,0,5,0"/>
                    <TextBox Text="{Binding AlertLevel, UpdateSourceTrigger=PropertyChanged}" 
                             Width="80" Background="#2d2d2d" Foreground="White" 
                             BorderBrush="#ff3355" Padding="5" VerticalContentAlignment="Center"/>

                    <Button Command="{Binding TogglePauseCommand}" Margin="15,0,0,0" Width="90" Height="30"
                            Background="{Binding IsPaused, Converter={StaticResource PauseColorConverter}}">
                        <TextBlock Text="{Binding IsPaused, Converter={StaticResource PauseTextConverter}}"/>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="🔍 Zoom:" VerticalAlignment="Center" Foreground="Gray" Margin="0,0,10,0"/>
                    <Slider Value="{Binding VisiblePointCount}" Minimum="10" Maximum="200" Width="150" VerticalAlignment="Center"
                            TickFrequency="10" IsSnapToTickEnabled="True"/>
                    <TextBlock Text="{Binding VisiblePointCount}" Foreground="SpringGreen" VerticalAlignment="Center" Margin="10,0" FontWeight="Bold"/>

                    <Separator Width="1" Height="20" Background="#333" Margin="20,0"/>

                    <Button Command="{Binding BuyCryptoCommand}" Content="VÉTEL (All-in)" Background="#2E7D32" Foreground="White" FontWeight="Bold" Width="110" Height="35" Margin="5,0"/>
                    <Button Command="{Binding SellCryptoCommand}" Content="ELADÁS (All)" Background="#C62828" Foreground="White" FontWeight="Bold" Width="110" Height="35" Margin="5,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="● AI Engine Aktív" Foreground="#4CAF50" FontSize="11" HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding CryptoInventory, StringFormat='Vagyon: {0:N4} unit'}" Foreground="Gray" FontSize="10" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <tb:TaskbarIcon x:Name="MyNotifyIcon" IconSource="/bitcoin.ico" ToolTipText="Crypto AI Tracker" TrayMouseDoubleClick="MyNotifyIcon_TrayMouseDoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu Style="{StaticResource ModernContextMenu}">
                    <MenuItem Header="Megnyitás" Click="Open_Click" FontWeight="Bold"/>
                    <Separator Background="#3d3d3d" Margin="5,2"/>
                    <MenuItem Header="Kilépés" Click="Exit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</Window>